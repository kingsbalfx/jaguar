# Bot Configuration Example
# Copy this file to .env and fill in YOUR values

# ========== WHAT TO TRADE ==========
BOT_ENABLED=true                    # true = ON, false = OFF
RISK_PER_TRADE=1.0                  # % of money to risk per trade
MAX_OPEN_TRADES=5                   # Max open trades at once

# ========== CONNECT TO MT5 ==========
# MT5 credentials are stored in Supabase via the Admin panel (not in env files).

# ========== MT5 RUNTIME FALLBACK ==========
# If MT5 is unavailable (e.g., Linux Render), keep API alive instead of crashing.
# Set false on dedicated Windows MT5 hosts if you want hard-fail behavior.
MT5_FALLBACK_API_ONLY=true

# ========== DATABASE (SUPABASE) ==========
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# ========== LOGGING ==========
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR
LOG_FILE=bot.log

# ========== BOT SERVER ==========
API_PORT=8000
API_HOST=0.0.0.0

# ========== MULTI-ACCOUNT AUTO RUN ==========
# If enabled, running `python main.py` becomes a supervisor that launches one child bot per account.
MULTI_ACCOUNT_ENABLED=false
MULTI_ACCOUNT_BASE_API_PORT=8000
MULTI_ACCOUNT_RESTART_ON_EXIT=false
MULTI_ACCOUNT_LOAD_SERVER=true
MULTI_ACCOUNT_LOAD_CONFIG=true
MULTI_ACCOUNT_ALLOW_SHARED_TERMINAL=false

# The shared SYMBOLS setting above stays unchanged and is inherited by all enabled accounts.
# Accounts can load from BOTH:
# 1) server-side mt5_credentials rows in Supabase
# 2) env entries below
# Env entries override the same login if both exist.

ACCOUNT_1_ENABLED=true
ACCOUNT_1_LOGIN=3611136
# Optional if this login is not stored in Supabase mt5_credentials:
# ACCOUNT_1_PASSWORD=your_mt5_password
# ACCOUNT_1_SERVER=YourBroker-Server
# ACCOUNT_1_MT5_PATH=C:\Path\To\MT5_Account1\terminal64.exe

ACCOUNT_2_ENABLED=false
ACCOUNT_2_LOGIN=
# ACCOUNT_2_PASSWORD=
# ACCOUNT_2_SERVER=
# ACCOUNT_2_MT5_PATH=C:\Path\To\MT5_Account2\terminal64.exe

ACCOUNT_3_ENABLED=false
ACCOUNT_3_LOGIN=

# Optional per-account overrides if needed later:
# ACCOUNT_2_API_PORT=8001
# ACCOUNT_2_BOT_ID=windows_mt5_bot_account_2
# ACCOUNT_2_BACKTEST_REPORT_PATH=backtest/latest_approval_account2.json
# ACCOUNT_2_SYMBOLS=BTCUSD,ETHUSD

# Option 2: JSON env accounts (overrides indexed accounts if set)
# MULTI_ACCOUNT_ACCOUNTS_JSON={"accounts":[{"enabled":true,"login":"3611136","bot_id":"windows_mt5_bot_3611136","api_port":8000}]}
