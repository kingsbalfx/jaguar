# Bot Configuration Example
# Copy this file to .env and fill in YOUR values

# ========== WHAT TO TRADE ==========
BOT_ENABLED=true                    # true = ON, false = OFF
RISK_PER_TRADE=1.0                  # % of money to risk per trade
MAX_OPEN_TRADES=5                   # Max open trades at once

# Optional: scan symbols directly from the connected MT5 terminal instead of the static config list.
AUTO_EXTRACT_MT5_SYMBOLS=false
# Optional MT5 symbol filters. Leave empty to scan every broker-tradable symbol MT5 exposes.
MT5_SYMBOL_GROUPS=
MT5_SYMBOL_ASSET_CLASSES=forex,metals,crypto,other
MT5_SYMBOL_ALLOWLIST=
MT5_SYMBOL_BLOCKLIST=
MT5_SYMBOL_INCLUDE_HIDDEN=false
MT5_SYMBOL_REQUIRE_TRADE=true
MT5_SYMBOL_REQUIRE_TICK=false
MT5_SYMBOL_LIMIT=

# ========== CONNECT TO MT5 ==========
# MT5 credentials are stored in Supabase via the Admin panel (not in env files).

# ========== MT5 RUNTIME FALLBACK ==========
# If MT5 is unavailable (e.g., Linux Render), keep API alive instead of crashing.
# Set false on dedicated Windows MT5 hosts if you want hard-fail behavior.
MT5_FALLBACK_API_ONLY=true

# ========== DATABASE (SUPABASE) ==========
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# ========== INTELLIGENCE SYSTEM ==========
# Advisory-only mode: Intelligence learns and provides insights but NEVER blocks execution
# Recommended: true (intelligence supports ICT decisions without preventing trades)
INTELLIGENCE_SUPPORT_ONLY=true

# ========== LOGGING ==========
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR
LOG_FILE=bot.log
# PowerShell prints conceptual reasoning for every state without raw price levels.
# SMT pairs include metals, mirrored FX pairs, DXY/USD pairs, crypto, and indices.

# ========== BOT SERVER ==========
API_PORT=8000
API_HOST=0.0.0.0
BOT_API_TOKEN=replace_with_a_long_random_token

# ========== UNIFIED STRATEGY & HARD SAFETY ==========
# Strict state-machine evidence and operational safety checks hard-block.
RISK_PER_TRADE=1.0
MAX_DAILY_LOSS_PERCENT=5.0
MAX_TICK_AGE_SECONDS=120
MAX_SPREAD_POINTS=80
SETUP_COOLDOWN_SECONDS=1800
SCAN_INTERVAL_SECONDS=60
SCAN_BATCH_SIZE=100
SCAN_BATCH_PAUSE_SECONDS=0
SCAN_WORKERS=1
STATE_LOG_MODE=compact              # compact, full, or none
SYMBOL_EVALUATION_LOGS=false        # true prints "[SYMBOL] EVALUATING" for every symbol
SYMBOL_SKIP_LOGS=false              # true prints market-closed/friday skips per symbol
ORDER_ROUTING_MODE=market
FRIDAY_CLOSE_HOUR_UTC=16

# ========== ICT / SMT CANDLE WINDOWS ==========
# Bot fetches a broad history, then each concept uses the matching recent window.
CANDLE_FETCH_PER_TIMEFRAME=500      # full history pulled per timeframe
HTF_CONTEXT_CANDLES=120             # D1/H4 narrative context
EXTERNAL_LIQUIDITY_CANDLES=200      # external liquidity context from D1,H4,H1,M30,M15
STRUCTURE_CANDLES=80                # MSS/BOS structure context
TRUE_FVG_OB_CONTEXT_CANDLES=100     # true FVG/OB validation context
SMT_CANDLES=20                      # SMT divergence window, valid range 10-50
SWEEP_CANDLES=20                    # liquidity sweep/reclaim window
DISPLACEMENT_CANDLES=10             # displacement/FVG trigger window
EXECUTION_CONFIRMATION_CANDLES=50   # M1/M5 confirmation window

# ========== MULTI-ACCOUNT AUTO RUN ==========
# If enabled, running `python main.py` becomes a supervisor that launches one child bot per account.
MULTI_ACCOUNT_ENABLED=false
MULTI_ACCOUNT_BASE_API_PORT=8000
MULTI_ACCOUNT_RESTART_ON_EXIT=false
MULTI_ACCOUNT_LOAD_SERVER=true
MULTI_ACCOUNT_LOAD_CONFIG=true
MULTI_ACCOUNT_ALLOW_SHARED_TERMINAL=false

# The shared SYMBOLS setting above stays unchanged and is inherited by all enabled accounts.
# Accounts can load from BOTH:
# 1) server-side mt5_credentials rows in Supabase
# 2) env entries below
# Env entries override the same login if both exist.

ACCOUNT_1_ENABLED=true
ACCOUNT_1_LOGIN=3611136
# Optional if this login is not stored in Supabase mt5_credentials:
# ACCOUNT_1_PASSWORD=your_mt5_password
# ACCOUNT_1_SERVER=YourBroker-Server
# ACCOUNT_1_MT5_PATH=C:\Path\To\MT5_Account1\terminal64.exe

ACCOUNT_2_ENABLED=false
ACCOUNT_2_LOGIN=
# ACCOUNT_2_PASSWORD=
# ACCOUNT_2_SERVER=
# ACCOUNT_2_MT5_PATH=C:\Path\To\MT5_Account2\terminal64.exe

ACCOUNT_3_ENABLED=false
ACCOUNT_3_LOGIN=

# Optional per-account overrides if needed later:
# ACCOUNT_2_API_PORT=8001
# ACCOUNT_2_BOT_ID=windows_mt5_bot_account_2
# ACCOUNT_2_BACKTEST_REPORT_PATH=backtest/latest_approval_account2.json
# ACCOUNT_2_SYMBOLS=BTCUSD,ETHUSD

# Option 2: JSON env accounts (overrides indexed accounts if set)
# MULTI_ACCOUNT_ACCOUNTS_JSON={"accounts":[{"enabled":true,"login":"3611136","bot_id":"windows_mt5_bot_3611136","api_port":8000}]}
