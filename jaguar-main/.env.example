# Public application URL
NEXT_PUBLIC_SITE_URL=https://example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Korapay
KORAPAY_SECRET_KEY=
KORAPAY_WEBHOOK_SECRET=

# Gmail SMTP lifecycle email
# Enable 2-Step Verification on the Gmail account, then create an App Password.
# Do not use your normal Gmail password. Spaces in the App Password are accepted.
SMTP_SERVICE=gmail
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=KINGSBALFX Academy <your-account@gmail.com>

# Vercel cron authorization
CRON_SECRET=

# MT5 encryption
MT5_CREDENTIALS_SECRET=
